{
  "_comment": "copy this file to .mcp.json and replace YOUR_PROJECT_REF with your actual Supabase project reference",
  "mcpServers": {
    "supabase": {
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--read-only",
        "--project-ref=YOUR_PROJECT_REF"
      ]
    }
  }
}
